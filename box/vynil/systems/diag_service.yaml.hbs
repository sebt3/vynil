{{#if (and (ctx_have_crd this "certificates.cert-manager.io") (ctx_have_crd this "issuers.cert-manager.io"))}}
---
apiVersion: v1
kind: Service
metadata:
  name: {{instance.appslug}}-diag
  labels:
    app.kubernetes.io/component: diag
spec:
  ports:
  - port: 443
    targetPort: 8443
    protocol: TCP
    name: https
  selector: {{json_to_str (selector_from_ctx this comp="diag")}}
---
apiVersion: apiregistration.k8s.io/v1
kind: APIService
metadata:
  name: v1.diag.vynil.solidite.fr
  annotations:
    cert-manager.io/inject-ca-from: {{instance.namespace}}/{{instance.appslug}}-diag
spec:
  group: diag.vynil.solidite.fr
  version: v1
  groupPriorityMinimum: 1000
  versionPriority: 15
  service:
    name: {{instance.appslug}}-diag
    namespace: {{instance.namespace}}
    port: 443
{{/if}}
