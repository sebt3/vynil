{{#if has_files}}
---
apiVersion: v1
kind: ConfigMap
metadata:
  name: "{{instance.appslug}}-backups-scripts"
data:
{{#each files}}
  {{name}}: {{json_to_str content}}
{{/each}}
{{/if}}
---
apiVersion: v1
kind: ServiceAccount
metadata:
  name: {{ instance.appslug }}-backup
---
apiVersion: rbac.authorization.k8s.io/v1
kind: RoleBinding
metadata:
  name: {{instance.appslug}}-backup
roleRef:
  apiGroup: rbac.authorization.k8s.io
  kind: ClusterRole
  name: {{cluster.vynil_namespace}}:backups
subjects:
- kind: ServiceAccount
  name: {{instance.appslug}}-backup
  namespace: {{instance.namespace}}
---
apiVersion: batch/v1
kind: CronJob
metadata:
  name: '{{instance.appslug}}-backups'
  annotations:
    ignore-check.kube-linter.io/env-value-from: "backup-settings secret is provisioned at runtime by the operator"
    ignore-check.kube-linter.io/no-liveness-probe: "CronJob containers do not need liveness probes"
    ignore-check.kube-linter.io/no-readiness-probe: "CronJob containers do not need readiness probes"
    ignore-check.kube-linter.io/no-read-only-root-fs: "Backup writes to /backup volume and requires writable container fs"
    ignore-check.kube-linter.io/non-isolated-pod: "Ephemeral backup pods do not require NetworkPolicy isolation"
    ignore-check.kube-linter.io/priority-class-name: "vynil-backup is a priority class provisioned by the operator"
    ignore-check.kube-linter.io/read-secret-from-env-var: "DB credentials must be env vars for backup scripts"
    ignore-check.kube-linter.io/env-var-secret: "Backup env vars named *secret* are required by restic and DB backup scripts"
    ignore-check.kube-linter.io/run-as-non-root: "Backup requires root for CHOWN/FOWNER filesystem operations"
spec:
  concurrencyPolicy: Forbid
  failedJobsHistoryLimit: 1
  schedule: {{schedule}}
  successfulJobsHistoryLimit: 3
  suspend: false
  jobTemplate:
    metadata:
      creationTimestamp: null
      labels: {{json_to_str (selector_from_ctx this comp="backup")}}
    spec:
      template: {{> backup.yaml}}
