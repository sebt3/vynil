---
apiVersion: v1
kind: Service
metadata:
  annotations: null
  name: '{{instance.appslug}}'
spec:
  ports:
  - name: web
    port: 80
    protocol: TCP
    targetPort: web
  - name: websecure
    port: 443
    protocol: TCP
    targetPort: websecure
  selector: {{json_to_str (selector_from_ctx this comp="app")}}
  type: LoadBalancer
