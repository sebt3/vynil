---
apiVersion: rbac.authorization.k8s.io/v1
kind: ClusterRoleBinding
metadata:
  name: '{{instance.namespace}}-{{instance.appslug}}'
roleRef:
  apiGroup: rbac.authorization.k8s.io
  kind: ClusterRole
  name: '{{instance.namespace}}-{{instance.appslug}}'
subjects:
- kind: ServiceAccount
  name: '{{instance.appslug}}'
  namespace: '{{instance.namespace}}'
